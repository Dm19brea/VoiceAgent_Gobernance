{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "uv run --no-dev celery -A src.infrastructure.celery.app.celery_app worker --loglevel=info",
    "restartPolicyType": "ON_FAILURE"
  }
}
