# Backend environment variables — copy to backend/.env and fill in real values.
# backend/.env is gitignored; this .env.example is committed as documentation only.

# --- Datastores ---
DATABASE_URL=postgresql+asyncpg://governance:governance@localhost:5432/governance
REDIS_URL=redis://localhost:6379/0

# --- Dashboard CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:3000

# --- OpenRouter conversation judge ---
# Get a key at https://openrouter.ai/keys . Never commit the real value.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SECONDS=10.0
