# =============================================================================
# CONFIGURACIÓN DEL STACK — VoiceAgent Gobernance (TFM)
# =============================================================================
#
# Este archivo es la REFERENCIA ÚNICA de configuración del stack completo,
# para los dos entornos soportados: LOCAL y RAILWAY.
#
# No se consume directamente: cada bloque indica DÓNDE copiar sus valores.
#
#   ┌─────────────────────────┬──────────────────────────────────────────────┐
#   │ Bloque                  │ Destino                                      │
#   ├─────────────────────────┼──────────────────────────────────────────────┤
#   │ 1. LOCAL — backend      │ backend/.env                                 │
#   │ 2. LOCAL — frontend     │ frontend/.env.local                          │
#   │ 3. RAILWAY — backend    │ Variables del servicio "backend" (dashboard) │
#   │ 4. RAILWAY — worker     │ Variables del servicio "worker" (dashboard)  │
#   │ 5. RAILWAY — frontend   │ Variables del servicio "frontend" (dashboard)│
#   └─────────────────────────┴──────────────────────────────────────────────┘
#
# ARQUITECTURA (idéntica en ambos entornos):
#
#   Vapi (nube) ──webhooks──> API FastAPI ──> Postgres
#                                  │
#                                  ├──> Redis (broker + sesiones activas)
#                                  └──> Worker Celery (evidencias async)
#   Dashboard Next.js ──HTTP/WS──> API FastAPI
#
# -----------------------------------------------------------------------------
# CÓMO LEVANTAR EL STACK EN LOCAL
# -----------------------------------------------------------------------------
#
#   1. Infraestructura:      docker compose up -d db redis
#   2. Backend (backend/):   crea backend/.env con el bloque 1 y ejecuta:
#                              uv run alembic upgrade head
#                              uv run uvicorn src.main:app --port 8000
#   3. Worker (backend/):    uv run celery -A src.infrastructure.celery.app.celery_app worker --loglevel=info
#   4. Frontend (frontend/): crea frontend/.env.local con el bloque 2 y ejecuta:
#                              npm install && npm run dev
#   5. Webhooks de Vapi:     ngrok http 8000
#                            En el dashboard de Vapi, configura el Server URL
#                            del asistente como:
#                              https://<subdominio>.ngrok-free.app/webhooks/vapi
#   6. Verificación:         curl http://localhost:8000/health   → {"status":"ok"}
#                            Dashboard en http://localhost:3000
#
# -----------------------------------------------------------------------------
# CÓMO DESPLEGAR EN RAILWAY
# -----------------------------------------------------------------------------
#
#   El proyecto Railway tiene 5 servicios:
#
#   - Postgres  (plugin oficial; aporta la referencia ${{Postgres.DATABASE_URL}})
#   - Redis     (plugin oficial; aporta la referencia ${{Redis.REDIS_URL}})
#   - backend   (root dir: backend/, build con Dockerfile vía backend/railway.json;
#                el CMD del Dockerfile aplica migraciones Alembic y arranca uvicorn;
#                healthcheck: /health)
#   - worker    (root dir: backend/, mismo Dockerfile vía backend/railway.worker.json;
#                start command:
#                uv run --no-dev celery -A src.infrastructure.celery.app.celery_app worker --loglevel=info)
#   - frontend  (root dir: frontend/, build vía frontend/railway.json)
#
#   Copia los bloques 3, 4 y 5 en las variables de cada servicio del dashboard
#   de Railway. Las referencias ${{Servicio.VARIABLE}} las resuelve Railway.
#
#   IMPORTANTE:
#   - NEXT_PUBLIC_API_URL se lee en BUILD TIME: si cambia, hay que redesplegar
#     el frontend.
#   - Railway entrega DATABASE_URL como postgresql://...; el backend la
#     normaliza a postgresql+asyncpg:// automáticamente (Settings.async_database_url).
#   - El Server URL del asistente en Vapi debe apuntar al backend de Railway:
#       https://<backend>.up.railway.app/webhooks/vapi
#
# =============================================================================


# =============================================================================
# 1. LOCAL — BACKEND (API y worker Celery)      → copiar a: backend/.env
# =============================================================================
# La API y el worker comparten este mismo archivo. pydantic-settings lo lee
# automáticamente desde el directorio backend/ (config.py).

# Postgres del docker-compose.yml (usuario/clave/db: governance)
DATABASE_URL=postgresql+asyncpg://governance:governance@localhost:5432/governance

# Redis del docker-compose.yml (broker Celery + store de sesiones activas)
REDIS_URL=redis://localhost:6379/0

# Orígenes permitidos para el dashboard (CSV). En local basta el dev server.
CORS_ORIGINS=http://localhost:3000

# --- Proveedores externos (secretos: NUNCA commitear valores reales) ---

# API key de Vapi (dashboard de Vapi → API Keys)
VAPI_API_KEY=coloca-aqui-tu-api-key-de-vapi
VAPI_BASE_URL=https://api.vapi.ai
VAPI_TIMEOUT_SECONDS=10.0

# API key de OpenRouter (juez LLM del scoring)
OPENROUTER_API_KEY=coloca-aqui-tu-api-key-de-openrouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SECONDS=10.0

# Solo para tests: con valor 1, pydantic-settings ignora backend/.env
# (lo usa pytest para aislarse del dotenv del desarrollador). No lo definas
# en ejecución normal.
# GOVERNANCE_DISABLE_DOTENV=1


# =============================================================================
# 2. LOCAL — FRONTEND (Next.js)                 → copiar a: frontend/.env.local
# =============================================================================

# URL base de la API local. El WebSocket de sesiones activas se deriva de
# esta URL (ws://localhost:8000/ws/active-sessions).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Nivel de log del cliente: trace | debug | info | warn | error
NEXT_PUBLIC_LOG_LEVEL=info


# =============================================================================
# 3. RAILWAY — SERVICIO "backend"               → dashboard Railway
# =============================================================================

# Referencias resueltas por Railway a los plugins del proyecto
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}

# URL pública del servicio frontend (para CORS del dashboard)
CORS_ORIGINS=https://<frontend>.up.railway.app

# Mismos secretos que en local
VAPI_API_KEY=coloca-aqui-tu-api-key-de-vapi
VAPI_BASE_URL=https://api.vapi.ai
VAPI_TIMEOUT_SECONDS=10.0
OPENROUTER_API_KEY=coloca-aqui-tu-api-key-de-openrouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SECONDS=10.0

# PORT lo inyecta Railway automáticamente; el Dockerfile lo expande en el CMD.


# =============================================================================
# 4. RAILWAY — SERVICIO "worker" (Celery)       → dashboard Railway
# =============================================================================
# Mismo Dockerfile que el backend, con el start command de
# backend/railway.worker.json. Necesita las mismas conexiones (no expone HTTP).

DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}
VAPI_API_KEY=coloca-aqui-tu-api-key-de-vapi
VAPI_BASE_URL=https://api.vapi.ai
VAPI_TIMEOUT_SECONDS=10.0
OPENROUTER_API_KEY=coloca-aqui-tu-api-key-de-openrouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SECONDS=10.0


# =============================================================================
# 5. RAILWAY — SERVICIO "frontend" (Next.js)    → dashboard Railway
# =============================================================================

# URL pública del servicio backend. Se lee en BUILD TIME: cambiarla exige
# redesplegar. El WebSocket se deriva de ella
# (wss://<backend>.up.railway.app/ws/active-sessions).
NEXT_PUBLIC_API_URL=https://<backend>.up.railway.app
NEXT_PUBLIC_LOG_LEVEL=info
